# Telegram bot token de @BotFather
TELEGRAM_BOT_TOKEN=

# (Opcional) IDs de chat permitidos, separados por coma. Si vacío, acepta cualquiera.
# Para obtener el chat_id agrega el bot al grupo y envía un mensaje; el log lo imprimirá.
ALLOWED_CHAT_IDS=

# Google Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Modelo Gemini a usar
# - gemini-2.5-flash      : mejor calidad, free tier 5 RPM / 20 RPD
# - gemini-2.5-flash-lite : casi igual de bueno, free tier 15 RPM / 1000 RPD
GEMINI_MODEL=gemini-2.5-flash-lite

# Tope local de requests por minuto (para evitar 429). Pon 1 menos que el límite real.
GEMINI_RPM=14

# Ruta al JSON de service account (montado en /secrets/sa.json dentro del container)
GOOGLE_SERVICE_ACCOUNT_FILE=./secrets/sa.json

# ID del Google Sheet (la parte larga de la URL: /spreadsheets/d/<ID>/edit)
GOOGLE_SHEET_ID=

# Zona horaria para fechas/hojas mensuales (ej. America/Bogota)
TIMEZONE=America/Bogota

# Moneda por defecto si Gemini no la detecta
DEFAULT_CURRENCY=COP
